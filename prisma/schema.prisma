// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model AuthToken {
  id              String   @id
  merchantId      String
  authorizedAppId String?  @unique
  salesChannelId  String?
  type            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deleted         Boolean  @default(false)

  accessToken     String
  tokenType       String
  expiresIn       Int
  expireDate      DateTime
  refreshToken    String
  scope           String?
}

// ürün görüntülenmelerini gün bazlı tutuyoruz.
// her view için ayrı satır açmak yerine productId + date için tek satır
// upsert edip viewCount'u artırıyoruz böylece günlük özet direkt oluşuyor.

model ProductView {
  id         String   @id @default(cuid())
  productId  String
  date       String   // "2026-07-16" formatında, gün bazlı özet
  viewCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, date])
  @@index([productId])
}

// Saatlik görüntülenme kırılımı — günlük ProductView'a ek olarak
// "son 24 saat" grafiği için saat bazında tutuyoruz.
model ProductViewHourly {
  id         String   @id @default(cuid())
  productId  String
  date       String   // "2026-07-16"
  hour       Int      // 0-23
  viewCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, date, hour])
  @@index([productId, date])
}
